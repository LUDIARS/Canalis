{
  "name": "@ludiars/canalis",
  "version": "0.1.0",
  "description": "LUDIARS 共有データ取込パイプライン基盤 — crawl/scrape → clean/categorize → save/import の3ステージを契約で接続する。",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LUDIARS/Canalis.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "canalis": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./notion": {
      "types": "./dist/crawl/notion/index.d.ts",
      "default": "./dist/crawl/notion/index.js"
    },
    "./save": {
      "types": "./dist/save/index.d.ts",
      "default": "./dist/save/index.js"
    },
    "./llm": {
      "types": "./dist/llm/index.d.ts",
      "default": "./dist/llm/index.js"
    },
    "./youtube": {
      "types": "./dist/crawl/youtube/index.d.ts",
      "default": "./dist/crawl/youtube/index.js"
    },
    "./reddit": {
      "types": "./dist/crawl/reddit/index.d.ts",
      "default": "./dist/crawl/reddit/index.js"
    },
    "./website": {
      "types": "./dist/crawl/website/index.d.ts",
      "default": "./dist/crawl/website/index.js"
    },
    "./notion-public": {
      "types": "./dist/crawl/notion-public/index.d.ts",
      "default": "./dist/crawl/notion-public/index.js"
    },
    "./discord": {
      "types": "./dist/crawl/discord/index.d.ts",
      "default": "./dist/crawl/discord/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "cli": "tsx src/cli.ts"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.0",
    "kuzu": "^0.11.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "js-yaml": "^4.2.0",
    "playwright": "^1.44.0"
  }
}
